{
    "name": "ryanhellyer/production-stats",
    "description": "Production-ready performance monitoring for Laravel and Symfony - automatically track and inject performance statistics into HTML responses.",
    "keywords": ["laravel", "symfony", "performance", "monitoring", "stats", "production", "load-time"],
    "homepage": "https://ryan.hellyer.kiwi/projects/production-stats/",
    "type": "library",
    "license": "GPL-2.0",
    "authors": [
        {
            "name": "Ryan Hellyer",
            "email": "ryan@hellyer.kiwi"
        }
    ],
    "replace": {
        "ryanhellyer/laravel-production-stats": "self.version"
    },
    "require": {
        "php": "^8.2",
        "symfony/http-foundation": "^6.0|^7.0"
    },
    "require-dev": {
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "symfony/http-kernel": "^6.0|^7.0",
        "symfony/event-dispatcher": "^6.0|^7.0",
        "phpcsstandards/php_codesniffer": "^3.13|^4.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5|^12.5"
    },
    "suggest": {
        "illuminate/http": "Required for Laravel integration (auto-installed with Laravel)",
        "symfony/http-kernel": "Required for Symfony integration (auto-installed with Symfony)"
    },
    "autoload": {
        "psr-4": {
            "RyanHellyer\\ProductionStats\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RyanHellyer\\ProductionStats\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "RyanHellyer\\ProductionStats\\Laravel\\ProductionStatsServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-core": "phpunit --testsuite Core",
        "test-laravel": "phpunit --testsuite Laravel",
        "test-symfony": "phpunit --testsuite Symfony",
        "lint": "phpcs",
        "lint-fix": "phpcbf",
        "analyze": "phpstan"
    }
}